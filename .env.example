# Postgres connection string. Railway injects this automatically when you
# add a Postgres plugin and reference ${{Postgres.DATABASE_URL}} in the service vars.
DATABASE_URL=postgres://user:password@localhost:5432/splitter

# Used to sign the session cookie value. Generate with: openssl rand -hex 32
AUTH_SECRET=change-me

# Production only. adapter-node sits behind Railway's HTTPS proxy, so SvelteKit
# needs the public origin to pass its cross-site form-POST (CSRF) check and to
# set secure cookies. Set this in Railway to your public URL, e.g.
# ORIGIN=https://splitter-production.up.railway.app
# NODE_ENV=production
